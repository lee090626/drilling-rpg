{
  "name": "drilling-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:gh": "IS_EXPORT=true NEXT_PUBLIC_BASE_PATH=/drilling-rpg BASE_PATH=/drilling-rpg next build",
    "build:itch": "IS_EXPORT=true NEXT_PUBLIC_BASE_PATH='' BASE_PATH='' next build",
    "build:cf": "IS_EXPORT=true NEXT_PUBLIC_BASE_PATH='' BASE_PATH='' next build",
    "start": "next start",
    "lint": "eslint",
    "deploy": "npm run build:gh && touch out/.nojekyll && gh-pages -t -d out",
    "deploy:cf": "npm run build:cf && wrangler pages deploy out",
    "optimize:images": "node scripts/optimize-assets.mjs",
    "optimize:atlas": "node scripts/generate-atlas.mjs"
  },
  "dependencies": {
    "free-tex-packer-core": "^0.3.5",
    "glob": "^13.0.6",
    "next": "^15.1.0",
    "pixi.js": "^8.17.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-scrollbar-hide": "^4.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.78.0"
  }
}
